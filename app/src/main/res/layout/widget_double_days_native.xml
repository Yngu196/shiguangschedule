<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/inner_content_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_rounded"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_current_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textColor="@color/widget_text_secondary"
            android:textSize="10dp"
            tools:text="第 18 周" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_today_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/widget_text_secondary"
                            android:textSize="11dp"
                            android:textStyle="bold"
                            tools:text="今日 1.07 周三" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal" />

                        <TextView
                            android:id="@+id/tv_today_footer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/widget_text_hint"
                            android:textSize="8dp"
                            tools:text="剩余 2 节" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_today"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">
                        <include layout="@layout/widget_item_course_common" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/empty_today_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/empty_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="无课程"
                        android:textColor="@color/widget_text_hint"
                        android:textSize="12dp" />
                </LinearLayout>
            </RelativeLayout>

            <ImageView
                android:id="@+id/widget_divider"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="8dp"
                android:layout_marginVertical="8dp"
                android:alpha="0.2"
                android:background="@color/widget_divider" />

            <RelativeLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_tomorrow_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/widget_text_secondary"
                            android:textSize="11dp"
                            android:textStyle="bold"
                            tools:text="明日 1.08 周四" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1"
                            android:orientation="horizontal" />

                        <TextView
                            android:id="@+id/tv_tomorrow_footer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/widget_text_hint"
                            android:textSize="8dp"
                            tools:text="共有 4 节" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/container_tomorrow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical">
                        <include layout="@layout/widget_item_course_common" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/empty_tomorrow_container"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/empty_tomorrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="无课程"
                        android:textColor="@color/widget_text_hint"
                        android:textSize="12dp" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_vacation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_bg_rounded"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
        <TextView
            android:id="@+id/tv_vacation_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_primary"
            android:textSize="18dp"
            android:textStyle="bold"
            tools:text="暑假快乐" />
        <TextView
            android:id="@+id/tv_vacation_msg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/widget_text_secondary"
            android:textSize="13dp"
            tools:text="愿你的假期充满阳光" />
        <FrameLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />
    </LinearLayout>
</RelativeLayout>