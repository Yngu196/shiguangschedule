<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.shiguangschedule" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/Animation.App.Activity</item>
    </style>

    <style name="Animation.App.Activity" parent="@android:style/Animation.Activity">
        <!-- 禁用 Activity 级别的动画，将转场动画交给 Compose Navigation 处理 -->
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
    </style>
</resources>
